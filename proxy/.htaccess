# Serve
Options -Indexes
<IfModule mod_rewrite.c>
  RewriteEngine on
  RewriteCond %{REQUEST_URI} ^/civicrm/ajax/api4
  RewriteRule ^civicrm/ajax/api4/([^/]*)/([^/]*) rest4.php?entity=$1&action=$2 [QSA,B]
</IfModule>

<FilesMatch "(secrets|config).php">
  <IfModule !authz_core_module>
    Order Deny,Allow
    Deny from all
  </IfModule>

# Apache 2.4+
  <IfModule authz_core_module>
    Require all denied
  </IfModule>
</FilesMatch>
